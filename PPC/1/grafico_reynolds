set terminal pngcairo size 800,600 enhanced font 'Arial,12'
set output 'grafico_reynolds.png'

# Título do gráfico
set title "Perfil de Velocidade para Diferentes Números de Reynolds"

# Rótulos dos eixos (Escala de tempo e velocidade)
set xlabel "Tempo adimensional (t^*)"
set ylabel "Velocidade adimensional (v_z^*)"

# Configuração da grade de fundo
set grid

# Posição da legenda
set key bottom right box

# Comando principal de plotagem
# O "lw 2" (line width)
# O "lc rgb" (line color)
plot "dados_velocidade_0.dat" using 1:2 with lines lw 2 lc rgb "#00FFFF" title "Re = 0", \
     "dados_velocidade_02.dat" using 1:2 with lines lw 2 lc rgb "#20B2AA" title "Re = 0.2", \
     "dados_velocidade_04.dat" using 1:2 with lines lw 2 lc rgb "#FFD700" title "Re = 0.4", \
     "dados_velocidade_06.dat" using 1:2 with lines lw 2 lc rgb "#FF0000" title "Re = 0.6", \
     "dados_velocidade_08.dat" using 1:2 with lines lw 2 lc rgb "#000000" title "Re = 0.8", \
     "dados_velocidade_1.dat" using 1:2 with lines lw 2 lc rgb "#C8A2C8" title "Re = 1"
     
