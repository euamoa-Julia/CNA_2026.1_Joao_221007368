set terminal pngcairo size 800,600 enhanced font 'Arial,12'
set output 'grafico_stokes.png'

# Título do gráfico
set title "Perfil de Velocidade para Diferentes Números de Stokes"

# Rótulos dos eixos (Escala de tempo e velocidade)
set xlabel "Tempo adimensional (t^*)"
set ylabel "Velocidade adimensional (v_z^*)"

# Configuração da grade de fundo
set grid

# Posição da legenda
set key bottom right box

# Função da solução analítica (onde x é o tempo)
v_exato(x, st) = 1 - exp(-x/st)

# Comando principal de plotagem
# Os dados numéricos usam "points" (bolinhas) para não esconder a linha analítica
# A solução analítica (v_exato) usa "lines" com a mesma cor, usando "notitle" para não duplicar a legenda
plot "dados_velocidade_S02.dat" using 1:2 with points pt 7 ps 0.6 lc rgb "#00FFFF" title "S = 0.2", \
     v_exato(x, 0.2) with lines lw 2 lc rgb "#00FFFF" title "S = 0.2 analítica", \
     "dados_velocidade_S04.dat" using 1:2 with points pt 7 ps 0.6 lc rgb "#20B2AA" title "S = 0.4", \
     v_exato(x, 0.4) with lines lw 2 lc rgb "#20B2AA" title "S = 0.4 analítica", \
     "dados_velocidade_S06.dat" using 1:2 with points pt 7 ps 0.6 lc rgb "#FFD700" title "S = 0.6", \
     v_exato(x, 0.6) with lines lw 2 lc rgb "#FFD700" title "S = 0.6 analítica", \
     "dados_velocidade_S08.dat" using 1:2 with points pt 7 ps 0.6 lc rgb "#FF0000" title "S = 0.8", \
     v_exato(x, 0.8) with lines lw 2 lc rgb "#FF0000" title "S = 0.8 analítica", \
     "dados_velocidade_S1.dat" using 1:2 with points pt 7 ps 0.6 lc rgb "#000000" title "S = 1", \
     v_exato(x, 1.0) with lines lw 2 lc rgb "#000000" title "S = 1 analítica"
